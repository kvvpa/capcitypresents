---
import type { EventEntry } from '../lib/events';
import { formatEventDate } from '../lib/events';

const { event } = Astro.props as { event: EventEntry };
const href = `/events/${event.slug}/`;
const poster = event.data.poster || '/default-poster.svg';
const posterAlt = event.data.poster ? `${event.data.title} poster` : 'CapCity Presents poster coming soon';
---
<article class="card event-card">
  <a href={href} aria-label={`View event details for ${event.data.title}`}>
    <div class="poster-frame">
      <img src={poster} alt={posterAlt} />
    </div>
  </a>
  <time datetime={event.data.date}>{formatEventDate(event)}</time>
  <h3><a href={href}>{event.data.title}</a></h3>
  <p class="meta">{event.data.venue} / {event.data.city}</p>
  <p class="meta">
    {event.data.ageRestriction || 'Age policy TBA'}
    {(event.data.doorsTime || event.data.showTime) ? ' / ' : ''}
    {event.data.doorsTime ? `Doors ${event.data.doorsTime}` : ''}
    {event.data.doorsTime && event.data.showTime ? ' / ' : ''}
    {event.data.showTime ? `Show ${event.data.showTime}` : ''}
  </p>
  <div class="actions"><a class="button" href={href}>View event details</a></div>
</article>
