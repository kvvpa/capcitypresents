---
import { site } from '../data/site';
---
<footer class="footer">
  <div class="container footer-inner">
    <span>&copy; 2015-2026 {site.name} - {site.location}</span>
    <nav class="footer-social" aria-label="Social media">
      <a href={site.facebook} aria-label="CapCity Presents on Facebook">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14 8h2V5h-2c-2.2 0-4 1.8-4 4v2H8v3h2v6h3v-6h2.4l.6-3h-3V9c0-.6.4-1 1-1Z" />
        </svg>
      </a>
      <a href={site.instagram} aria-label="CapCity Presents on Instagram">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <rect x="5" y="5" width="14" height="14" rx="4" ry="4" />
          <circle cx="12" cy="12" r="3.2" />
          <circle cx="16.5" cy="7.5" r=".9" />
        </svg>
      </a>
    </nav>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/logo-assets/">Logo assets</a> / <a href="/privacy/">Privacy</a> / <a href="/terms/">Terms</a>
    </nav>
  </div>
</footer>
