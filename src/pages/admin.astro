<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CapCity Presents Admin</title>
  </head>
  <body>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      (() => {
        const identityTokenPattern = /^#\/?(invite_token|confirmation_token|recovery_token|email_change_token|access_token)=/;
        const hasIdentityToken = () => identityTokenPattern.test(window.location.hash);
        const normalizeIdentityHash = () => {
          if (window.location.hash.startsWith('#/')) {
            window.history.replaceState(null, '', `${window.location.pathname}${window.location.search}#${window.location.hash.slice(2)}`);
          }
        };
        const loadDecap = () => {
          if (document.querySelector('script[data-decap-cms]')) return;
          const script = document.createElement('script');
          script.src = 'https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js';
          script.dataset.decapCms = 'true';
          document.body.appendChild(script);
        };

        normalizeIdentityHash();

        if (!window.netlifyIdentity) {
          loadDecap();
          return;
        }

        window.netlifyIdentity.on('init', () => {
          normalizeIdentityHash();
          if (hasIdentityToken()) {
            window.netlifyIdentity.open();
            return;
          }
          loadDecap();
        });

        window.netlifyIdentity.on('login', () => {
          window.location.href = '/admin/';
        });

        window.netlifyIdentity.on('close', () => {
          normalizeIdentityHash();
          if (!hasIdentityToken()) loadDecap();
        });
      })();
    </script>
  </body>
</html>
