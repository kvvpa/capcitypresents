---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---
<BaseLayout title="Booking" description="Book a show with CapCity Presents.">
  <section class="hero">
    <div class="container split">
      <div>
        <p class="eyebrow">Booking</p>
        <h1>Booking inquiries</h1>
      </div>
      <div class="panel prose">
        <p>For booking, collaborations, venue questions, or event ideas, send the date range, lineup, venue, ticketing details, and anything already confirmed.</p>
        <p>If the event is still early, that is fine. Include what you know and the best way to reach you.</p>
        <div class="actions"><a class="button primary" href={`mailto:${site.email}`}>Email booking</a><a class="button" href="/contact/">Contact info</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
