---
const groups = [
  {
    title: 'Full resolution',
    note: 'Best for print layouts and designer source files.',
    base: '/logo/full/',
  },
  {
    title: 'Optimized',
    note: 'Smaller web-ready exports.',
    base: '/logo/opt/',
  },
  {
    title: 'Optimized 640px',
    note: 'Mid-size web exports.',
    base: '/logo/opt-640/',
  },
  {
    title: 'Optimized 320px',
    note: 'Small web exports and quick previews.',
    base: '/logo/opt-320/',
  },
];

const files = [
  { label: 'Logo JPG', filename: 'logo.jpg' },
  { label: 'Textured JPG', filename: 'logotextured.jpg' },
  { label: 'Black transparent PNG', filename: 'logo-blk-alltrans.png' },
  { label: 'Textured black transparent PNG', filename: 'logo-txt-blk-alltrans.png' },
  { label: 'Textured black with white text PNG', filename: 'logo-txt-blk-whttext.png' },
  { label: 'Textured white PNG', filename: 'logo-txt-wht.png' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CapCity Presents Logo Assets</title>
    <meta name="description" content="Standalone CapCity Presents logo asset download page for designers." />
    <link rel="icon" href="/images/fav/favicon-32x32.png" />
  </head>
  <body>
    <main class="wrap">
      <section class="intro">
        <img src="/logo/opt-320/logo-txt-wht.png" alt="CapCity Presents" />
        <p class="eyebrow">Designer files</p>
        <h1>CapCity Presents Logo Assets</h1>
        <p>Current CapCity logo exports for flyers, posters, web graphics, and press use. Use the existing files as provided; do not redraw, stretch, or rebuild the mark.</p>
        <a class="quiet-link" href="/about/">Back to CapCity site</a>
      </section>

      <section class="groups" aria-label="Logo asset downloads">
        {groups.map((group) => (
          <article class="asset-group">
            <div>
              <h2>{group.title}</h2>
              <p>{group.note}</p>
            </div>
            <div class="asset-links">
              {files.map((file) => (
                <a href={`${group.base}${file.filename}`} download>
                  <span>{file.label}</span>
                  <small>{file.filename}</small>
                </a>
              ))}
            </div>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #050505;
    --ink: #f5f0e8;
    --muted: #b8afa7;
    --line: rgba(245, 240, 232, .16);
    --hot: #ff4d2d;
    --gold: #f5b84b;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-height: 100vh;
    background: #050505;
    color: var(--ink);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.5;
  }

  a { color: inherit; }

  .wrap {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 42px 0 56px;
  }

  .intro {
    border-bottom: 1px solid var(--line);
    padding-bottom: 32px;
    margin-bottom: 28px;
  }

  .intro img {
    width: min(260px, 72vw);
    height: auto;
    margin-bottom: 24px;
  }

  .eyebrow {
    color: var(--gold);
    font-size: .76rem;
    font-weight: 900;
    letter-spacing: .16em;
    margin: 0 0 8px;
    text-transform: uppercase;
  }

  h1, h2 { margin: 0; line-height: .98; letter-spacing: -.05em; text-transform: uppercase; }
  h1 { max-width: 820px; font-size: clamp(3rem, 8vw, 6rem); }
  h2 { font-size: clamp(1.7rem, 4vw, 3rem); }

  p {
    max-width: 680px;
    color: var(--muted);
    margin: 14px 0 0;
  }

  .quiet-link {
    display: inline-flex;
    margin-top: 22px;
    color: var(--gold);
    font-weight: 800;
    text-decoration: none;
  }

  .quiet-link:hover { color: var(--hot); }

  .groups { display: grid; gap: 18px; }

  .asset-group {
    display: grid;
    grid-template-columns: .8fr 1.2fr;
    gap: 22px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 20px;
    background: rgba(255, 255, 255, .045);
  }

  .asset-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .asset-links a {
    display: grid;
    gap: 3px;
    min-height: 64px;
    justify-content: start;
    align-content: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 11px 13px;
    text-decoration: none;
    background: rgba(0, 0, 0, .28);
  }

  .asset-links a:hover {
    border-color: rgba(245, 184, 75, .55);
    color: var(--gold);
  }

  .asset-links span { font-weight: 900; }
  .asset-links small { color: var(--muted); overflow-wrap: anywhere; }

  @media (max-width: 760px) {
    .asset-group, .asset-links { grid-template-columns: 1fr; }
    .wrap { width: min(100% - 24px, 1120px); padding-top: 28px; }
  }
</style>
