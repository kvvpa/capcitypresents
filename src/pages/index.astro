---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import { site } from '../data/site';
import { sortUpcoming, formatEventDate } from '../lib/events';

const allEvents = await getCollection('events');
const upcoming = sortUpcoming(allEvents);
const featured = upcoming.find((event) => event.data.featured) ?? upcoming[0];
---
<BaseLayout title={site.name} description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Olympia, WA / DIY live music</p>
        <h1>Oly, amplified.</h1>
        <p class="lede">CapCity Presents books Olympia shows with roots in hardcore, punk, metal, and DIY spaces. Clear dates, ticket links, age info, and booking contact stay up front because shows should be easy to find and easy to get to.</p>
        <div class="actions">
          <a class="button primary" href="/events/">See upcoming shows</a>
          <a class="button" href="/booking/">Ask about booking</a>
        </div>
      </div>
      <aside class="card hero-card">
        {featured ? (
          <>
            <p class="eyebrow">Next show</p>
            <div class="big-date">{new Date(`${featured.data.date}T12:00:00`).toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}</div>
            <h3><a href={`/events/${featured.slug}/`}>{featured.data.title}</a></h3>
            <p class="meta">{formatEventDate(featured)} / {featured.data.venue}</p>
          </>
        ) : (
          <>
            <p class="eyebrow">Shows</p>
            <h3>No upcoming shows posted yet.</h3>
            <p class="meta">Check back soon or follow CapCity Presents for new Olympia announcements.</p>
          </>
        )}
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Upcoming shows</h2>
        <p>Posters, lineups, ticket links, and show details for the next CapCity dates.</p>
      </div>
      <div class="event-grid">
        {upcoming.slice(0, 3).map((event) => <EventCard event={event} />)}
      </div>
      <div class="actions"><a class="button" href="/events/">View all shows</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="panel">
        <p class="eyebrow">Roots</p>
        <h2>DIY and all-ages by default.</h2>
      </div>
      <div class="panel prose">
        <p>CapCity came out of Olympia's hardcore, punk, and metal scene, where all-ages access and DIY work are not decoration. They are part of the point.</p>
        <p>The goal is still simple: help local and touring artists put together shows that make sense for the room, the bill, and the people trying to be there.</p>
        <div class="actions"><a class="button" href="/about/">About CapCity</a></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="panel">
        <p class="eyebrow">Booking</p>
        <h2>Bringing a show through Olympia?</h2>
      </div>
      <div class="panel prose">
        <p>Send the date range, lineup, venue details if you have them, ticketing notes, and anything already confirmed.</p>
        <p>If the idea is still early, that is fine. Share what you know and the best way to reach you.</p>
        <div class="actions"><a class="button" href="/booking/">Email booking</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
