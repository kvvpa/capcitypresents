---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import { site } from '../data/site';
import { sortUpcoming, formatEventDate } from '../lib/events';

const allEvents = await getCollection('events');
const upcoming = sortUpcoming(allEvents);
const featured = upcoming.find((event) => event.data.featured) ?? upcoming[0];
---
<BaseLayout title={site.name} description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Olympia, WA / live events</p>
        <h1>Oly, amplified.</h1>
        <p class="lede">Independent live events in Olympia, Washington. Find upcoming shows, venue details, ticket links, and booking contact info here.</p>
        <div class="actions">
          <a class="button primary" href="/events/">Upcoming events</a>
          <a class="button" href="/booking/">Booking info</a>
        </div>
      </div>
      <aside class="card hero-card">
        {featured ? (
          <>
            <p class="eyebrow">Next event</p>
            <div class="big-date">{new Date(`${featured.data.date}T12:00:00`).toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}</div>
            <h3><a href={`/events/${featured.slug}/`}>{featured.data.title}</a></h3>
            <p class="meta">{formatEventDate(featured)} / {featured.data.venue}</p>
          </>
        ) : (
          <>
            <p class="eyebrow">Events</p>
            <h3>No upcoming events posted yet.</h3>
            <p class="meta">Check back soon or follow CapCity Presents on social media.</p>
          </>
        )}
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Upcoming events</h2>
        <p>Dates, venues, ticket links, and Facebook event links when available.</p>
      </div>
      <div class="event-grid">
        {upcoming.slice(0, 3).map((event) => <EventCard event={event} />)}
      </div>
      <div class="actions"><a class="button" href="/events/">View all events</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="panel">
        <p class="eyebrow">Booking</p>
        <h2>Booking and event inquiries</h2>
      </div>
      <div class="panel prose">
        <p>For booking, collaborations, or event questions, send the date range, venue, lineup, ticketing details, and anything already confirmed.</p>
        <p>Use the booking page for the best contact info.</p>
      </div>
    </div>
  </section>
</BaseLayout>
