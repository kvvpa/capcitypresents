---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import { site } from '../data/site';
import { sortUpcoming, formatEventDate } from '../lib/events';

const allEvents = await getCollection('events');
const upcoming = sortUpcoming(allEvents);
const featured = upcoming.find((event) => event.data.featured) ?? upcoming[0];
---
<BaseLayout title={site.name} description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Olympia, WA / independent live events</p>
        <h1>Shows in the room.</h1>
        <p class="lede">CapCity Presents books and promotes live events in Olympia, Washington. Show details live here first: date, room, doors, tickets, and the link you actually need.</p>
        <div class="actions">
          <a class="button primary" href="/events/">See upcoming shows</a>
          <a class="button" href="/booking/">Book a show</a>
        </div>
      </div>
      <aside class="card hero-card">
        {featured ? (
          <>
            <p class="eyebrow">Next up</p>
            <div class="big-date">{new Date(`${featured.data.date}T12:00:00`).toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}</div>
            <h3><a href={`/events/${featured.slug}/`}>{featured.data.title}</a></h3>
            <p class="meta">{formatEventDate(featured)} / {featured.data.venue}</p>
          </>
        ) : (
          <>
            <p class="eyebrow">Calendar</p>
            <h3>Events will appear here.</h3>
            <p class="meta">Add shows from the admin panel after setup.</p>
          </>
        )}
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Upcoming</h2>
        <p>Official show listings. Facebook links can be included, but the website is the stable source.</p>
      </div>
      <div class="event-grid">
        {upcoming.slice(0, 3).map((event) => <EventCard event={event} />)}
      </div>
      <div class="actions"><a class="button" href="/events/">View all events</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="panel">
        <p class="eyebrow">Booking</p>
        <h2>Olympia first.</h2>
      </div>
      <div class="panel prose">
        <p>CapCity Presents works with artists, venues, and touring acts to put together shows that make sense for the room.</p>
        <p>For booking or event questions, send the date range, lineup, venue, ticketing details, and whatever is already confirmed.</p>
      </div>
    </div>
  </section>
</BaseLayout>
