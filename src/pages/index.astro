---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import { site } from '../data/site';
import { sortUpcoming, formatEventDate } from '../lib/events';

const allEvents = await getCollection('events');
const upcoming = sortUpcoming(allEvents);
const featured = upcoming.find((event) => event.data.featured) ?? upcoming[0];
---
<BaseLayout title={site.name} description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Olympia, WA / DIY live music</p>
        <h1>Oly, amplified.</h1>
        <p class="lede">CapCity Presents puts loud, heavy, heartfelt shows in Olympia rooms where they can actually hit. Local bills, touring bands, all-ages energy, and the strange little magic of getting everyone in the same place.</p>
        <div class="actions">
          <a class="button primary" href="/events/">See upcoming shows</a>
          <a class="button" href="/contact/">Ask about booking</a>
        </div>
      </div>
      <aside class="card hero-card">
        {featured ? (
          <>
            <p class="eyebrow">Next show</p>
            <div class="big-date">{new Date(`${featured.data.date}T12:00:00`).toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}</div>
            <h3><a href={`/events/${featured.slug}/`}>{featured.data.title}</a></h3>
            <p class="meta">{formatEventDate(featured)} / {featured.data.venue}</p>
          </>
        ) : (
          <>
            <p class="eyebrow">Shows</p>
            <h3>No upcoming shows posted yet.</h3>
            <p class="meta">Check back soon or follow CapCity Presents for new Olympia announcements.</p>
          </>
        )}
      </aside>
    </div>
  </section>

  <section class="section homepage-upcoming">
    <div class="container">
      <div class="section-head">
        <h2>Upcoming shows</h2>
        <p>Posters, lineups, ticket links, and show details for the next CapCity dates.</p>
      </div>
      <div class="event-grid">
        {upcoming.slice(0, 3).map((event) => <EventCard event={event} />)}
      </div>
      <div class="actions"><a class="button" href="/events/">View all shows</a></div>
    </div>
  </section>

  <section class="section roots-section">
    <div class="container roots-layout">
      <div class="roots-copy">
        <p class="eyebrow">Roots</p>
        <h2>From the loud rooms.</h2>
        <p>CapCity came up through Olympia's hardcore, punk, and metal world: all-ages rooms, borrowed gear, handbills, late nights, and people doing the work because the show mattered.</p>
        <p>That still shapes how the shows come together. The goal is to help local and touring bands find the right room, the right bill, and the people who will actually show up.</p>
        <div class="actions"><a class="button" href="/about/">About CapCity</a></div>
      </div>
      <div class="roots-media">
        <div class="archive-strip" aria-label="Archive photos from old CapCity shows">
          <img src="/assets/roots-archive-house-show.jpg" alt="Band playing in a small Olympia room" loading="lazy" />
          <img src="/assets/roots-archive-voyeur-pit.jpg" alt="Packed room during a punk show" loading="lazy" />
          <img src="/assets/roots-archive-crowd-surf.jpg" alt="Crowd surfer lifted above the room" loading="lazy" />
          <img src="/assets/roots-archive-stage-dive.jpg" alt="Performer held up by the crowd" loading="lazy" />
          <img src="/assets/roots-archive-room-crowd.jpg" alt="Audience packed close to the stage" loading="lazy" />
        </div>
        <div class="roots-proof">
          <div class="press-callout">
            <p class="eyebrow">In the press</p>
            <h3>Celebrating over 10 years of Olympia live music</h3>
            <p>Weekly Volcano looked back at CapCity's decade of independent shows, Andy's booking work, and the Olympia rooms that helped shape it.</p>
            <div class="actions">
              <a class="button" href="https://weekly-volcano.com/capcitys-decade-of-independent-music-in-olympia/" target="_blank" rel="noopener noreferrer">Read the feature</a>
            </div>
          </div>
          <div class="award-callout">
            <img
              src="/assets/best-of-south-sound-2024-winner-badge.png"
              alt="Best of South Sound 2024 Winner badge"
              loading="lazy"
            />
            <div>
              <p class="eyebrow">2024 Best of South Sound</p>
              <p><strong>Winner — Live Music</strong></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="panel">
        <p class="eyebrow">Booking</p>
        <h2>Bringing a show through Olympia?</h2>
      </div>
      <div class="panel prose">
        <p>Trying to route through Olympia, fill an open date, or build something from scratch? Send what you have: dates, bands, rough timing, venue ideas, ticket needs, or just the basic pitch.</p>
        <p>It does not need to be fully formed. If it feels like a fit, we can talk through the rest.</p>
        <div class="actions"><a class="button" href="/contact/">Contact CapCity</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
