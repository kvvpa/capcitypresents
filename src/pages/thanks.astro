---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Thanks" description="Thanks for contacting CapCity Presents.">
  <section class="hero">
    <div class="container split">
      <div>
        <p class="eyebrow">Message sent</p>
        <h1>Got it.</h1>
      </div>
      <div class="panel prose">
        <p>Your message went through. CapCity will follow up when someone has eyes on it.</p>
        <div class="actions"><a class="button primary" href="/events/">Back to shows</a><a class="button" href="/">Home</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
