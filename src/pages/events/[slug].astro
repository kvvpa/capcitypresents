---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatEventDate } from '../../lib/events';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({ params: { slug: event.slug }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const poster = event.data.poster || '/assets/default-poster.png';
const posterAlt = event.data.poster ? `${event.data.title} poster` : 'CapCity Presents poster coming soon';
const posterFallback = event.data.poster ? 'Poster unavailable' : 'Poster coming soon';
---
<BaseLayout title={event.data.title} description={`Get details for ${event.data.title} at ${event.data.venue} in ${event.data.city}, including date, doors, show time, age policy, and ticket info.`}>
  <section class="hero event-hero">
    <div class="container event-detail">
      <div class="card event-poster-card">
        <div class="poster-frame detail-poster-frame">
          <span class="poster-placeholder">{posterFallback}</span>
          <img
            src={poster}
            alt={posterAlt}
            onload="this.closest('.event-detail')?.classList.toggle('has-wide-poster', this.naturalWidth / this.naturalHeight > 1.12);"
            onerror="this.hidden = true;"
          />
        </div>
        <div class="actions event-poster-actions">
          <a class="button" href="/events/">Back to all events</a>
          {event.data.ticketUrl && <a class="button primary" href={event.data.ticketUrl}>Get tickets</a>}
          {event.data.facebookEventUrl && <a class="button" href={event.data.facebookEventUrl}>RSVP and share</a>}
        </div>
      </div>
      <div class="event-info">
        <p class="eyebrow">{event.data.status}</p>
        <h1>{event.data.title}</h1>
        <p class="lede">{formatEventDate(event)} / {event.data.venue} / {event.data.city}</p>
        <div class="panel" style="margin-top: 24px;">
          <p class="meta"><strong>Date:</strong> {formatEventDate(event)}</p>
          <p class="meta"><strong>Venue:</strong> {event.data.venue} / {event.data.city}</p>
          <p class="meta"><strong>Doors:</strong> {event.data.doorsTime || 'TBA'}</p>
          <p class="meta"><strong>Show:</strong> {event.data.showTime || 'TBA'}</p>
          <p class="meta"><strong>Age:</strong> {event.data.ageRestriction || 'TBA'}</p>
          <p class="meta"><strong>Price:</strong> {event.data.price || 'TBA'}</p>
        </div>
      </div>
      <div class="event-description prose"><Content /></div>
    </div>
  </section>
</BaseLayout>

<style>
  .event-detail {
    display: block;
  }

  .event-detail::after {
    clear: both;
    content: "";
    display: block;
  }

  .event-info {
    float: right;
    margin: 0 0 34px 28px;
    min-width: 0;
    width: calc(60% - 28px);
  }

  .event-info h1 {
    font-size: clamp(2.85rem, 5.6vw, 5.65rem);
  }

  .event-poster-card {
    float: left;
    margin: 0 28px 34px 0;
    width: calc(40% - 28px);
  }

  .detail-poster-frame {
    aspect-ratio: auto;
    display: block;
    min-height: 0;
    padding: 0;
  }

  .detail-poster-frame .poster-placeholder {
    position: static;
    min-height: min(70vh, 560px);
    padding: 20px;
  }

  .detail-poster-frame:has(img:not([hidden])) .poster-placeholder {
    display: none;
  }

  .detail-poster-frame img {
    position: static;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .event-poster-actions {
    margin: 0;
    padding: 14px;
    border-top: 1px solid var(--line);
    background: rgba(7,7,7,.2);
  }

  .event-poster-actions .button {
    flex: 1 1 150px;
  }

  .event-description {
    max-width: none;
  }

  .event-description > :first-child {
    margin-top: 0;
  }

  @media (min-width: 821px) {
    .event-detail.has-wide-poster .event-poster-card {
      width: calc(50% - 28px);
    }

    .event-detail.has-wide-poster .event-info {
      width: calc(50% - 28px);
    }

    .event-detail.has-wide-poster h1 {
      font-size: clamp(2.75rem, 5.2vw, 4.65rem);
    }
  }

  @media (max-width: 820px) {
    .event-info,
    .event-poster-card {
      float: none;
      margin: 0;
      width: 100%;
    }

    .event-info {
      margin-top: 18px;
    }

    .event-description {
      margin-top: 24px;
    }

    .event-info h1 {
      font-size: clamp(2.55rem, 11.5vw, 4.15rem);
    }
  }
</style>
