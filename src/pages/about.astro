---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="About CapCity Presents in Olympia, Washington.">
  <section class="hero">
    <div class="container split">
      <div>
        <p class="eyebrow">About</p>
        <h1>CapCity Presents</h1>
      </div>
      <div class="panel prose">
        <p>CapCity Presents is an Olympia, Washington live events project focused on booking, promoting, and sharing upcoming shows.</p>
        <p>This site lists current events, contact information, and booking details in one place.</p>
      </div>
    </div>
  </section>
</BaseLayout>
