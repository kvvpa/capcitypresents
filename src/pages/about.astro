---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="About CapCity Presents in Olympia, Washington.">
  <section class="hero">
    <div class="container split">
      <div>
        <p class="eyebrow">About</p>
        <h1>CapCity Presents</h1>
      </div>
      <div class="panel prose">
        <p>CapCity Presents books and promotes live events in Olympia, Washington.</p>
        <p>This site is being rebuilt around a real event calendar and a CMS so the show info can stay current without duct-taping everything to Facebook.</p>
      </div>
    </div>
  </section>
</BaseLayout>
