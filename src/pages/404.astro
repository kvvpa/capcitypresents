---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="The page you requested could not be found on CapCity Presents.">
  <section class="hero">
    <div class="container split">
      <div>
        <p class="eyebrow">404</p>
        <h1>Page not found</h1>
      </div>
      <div class="panel prose">
        <p>That page is not here anymore, or the link may have moved.</p>
        <div class="actions">
          <a class="button primary" href="/events/">See upcoming shows</a>
          <a class="button" href="/">Home</a>
          <a class="button" href="/contact/">Contact</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
