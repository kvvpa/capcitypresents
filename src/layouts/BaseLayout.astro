---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import { site } from '../data/site';

const { title = site.name, description = site.description } = Astro.props;
const pageTitle = title === site.name ? site.name : `${title} | ${site.name}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
const socialImageUrl = new URL(site.socialImage, site.url).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:width" content={site.socialImageWidth} />
    <meta property="og:image:height" content={site.socialImageHeight} />
    <meta property="og:image:alt" content="CapCity Presents logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{pageTitle}</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/images/fav/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/fav/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/fav/favicon-16x16.png" />
    <link rel="manifest" href="/images/fav/site.webmanifest" />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/">
          <img src="/logo/opt-320/logo-txt-wht.png" alt="CapCity Presents" />
          <span class="brand-fallback">CapCity Presents</span>
        </a>
        <nav class="nav-links" aria-label="Main navigation">
          <a href="/events/">Events</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="/admin/">Admin</a>
        </nav>
        <div class="mobile-nav">
          <a class="mobile-events-link" href="/events/">Events</a>
          <details class="mobile-menu">
            <summary>
              <span class="menu-mark" aria-hidden="true"></span>
              <span>Menu</span>
            </summary>
            <nav class="mobile-menu-panel" aria-label="Mobile navigation">
              <a href="/about/">About</a>
              <a href="/contact/">Contact</a>
              <a href="/admin/">Admin</a>
            </nav>
          </details>
        </div>
      </div>
    </header>
    <main><slot /></main>
    <SiteFooter />
  </body>
</html>
